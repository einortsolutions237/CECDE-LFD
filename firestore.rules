rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    function isSuperAdmin() {
      return (request.auth != null && request.auth.token.role == "super_admin") ||
        (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    // Role checks
    function isFinanceAdmin() { return isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleType == 'finance'; }
    function isSupportAdmin() { return isAdmin() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleType == 'support'; }

    // Whitelisted user fields for regular members
    function allowedUserUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fullName', 'firstName', 'lastName', 'phone', 'address', 'city', 'state', 'zip', 'country', 
        'profilePicture', 'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if true;
      // Strict whitelist on creation
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && 
         request.resource.data.keys().hasOnly(['role', 'roleType', 'currentRank', 'walletBalance', 'leaderboardScore', 'rankingScore', 'email', 'fullName', 'createdAt', 'updatedAt', 'phone', 'phoneNumber', 'country', 'status', 'accountStatus', 'activityState', 'sponsorId', 'referralCode', 'sponsorReferralCode', 'directReferralsCount', 'totalDownlineCount', 'activeDownlineCount', 'dormantDownlineCount', 'suspendedDownlineCount', 'searchKeywords', 'teamId']) &&
         request.resource.data.get('role', 'member') == 'member' &&
         request.resource.data.get('roleType', 'team_member') == 'team_member' &&
         request.resource.data.get('currentRank', 'Member') == 'Member' &&
         request.resource.data.get('walletBalance', 0) == 0
        ) || isAdmin()
      );
      // Strict whitelist on updates
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && allowedUserUpdateFields()) || isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    match /network/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can only update specific downline tracking fields
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['directReferrals', 'totalDownlineCount']))
      );
      allow delete: if isSuperAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teamLeaderId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /system_settings/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      // Users can only mark notifications as read
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
    }

    // New Immutable Modules

    match /wallets/{walletId} {
      allow read: if isSignedIn() && (request.auth.uid == walletId || isAdmin());
      allow write: if false; // Only Cloud Functions
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Only Cloud Functions
    }

    match /commissions/{commId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Only Cloud Functions
    }

    match /withdrawals/{reqId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId && request.resource.data.status == 'pending' && request.resource.data.keys().hasOnly(['userId', 'amount', 'method', 'status', 'createdAt']);
      allow update: if isAdmin(); // Only admins can approve/reject
      allow delete: if false;
    }
    
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
  }
}

